{
        "dataset": "mnist",
        "num_sims": 5,
        "server_epochs": 5,
        "user_epochs": 1,
        "users": 10,
        "model_params": {
                "architecture": "softmax",
                "device": "cuda:0",
                "batch_size": 512,
                "params_mul": 10,
                "learning_rate": [0.01],
                "lr_changes": []
        },
        "fit_fun": "foolsgold",
        "params": {
                "kappa": 2,
                "importance": false
        },
        "adversaries": {
                "percent_adv": 0.5,
                "type": "on off",
                "from": 5,
                "to": 0,
                "toggle_times": [500, 150],
                "delay": 1000
        },
        "class_shards": null,
        "classes_per_user": 2,
        "verbosity": 1,
        "result_file": "./results.pt"
}
